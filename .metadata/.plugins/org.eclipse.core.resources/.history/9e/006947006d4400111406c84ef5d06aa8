
public class Exam03 {
	public static void main(String[] args) {
		for (int i = 0; i < 16; i+=2) {
			for (int j = 14 ; j>=i ; j-=2) {
				System.out.printf(" ");
			}
			for (int k=0 ; k<=i ; k++) {
				System.out.printf("*");
			}
			System.out.println();
		}
		for (int i = 0; i < 16 ; i+=2) {
			for (int j = 0 ; j <= i ; j += 2) {
				System.out.printf(" ");
			}
			for (int k = 12 ; k >= i ; k--) {
				System.out.printf("*");
			}
			System.out.println();
		}
	}
}
