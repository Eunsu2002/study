
public class Exam03 {
	public static void main(String[] args) {
		for (int i = 0; i < 10; i+=2) {
			for (int j = 10 ; j>=i ; j-=2) {
				System.out.printf(" ");
			}
			for (int k=0 ; k<=i ; k++) {
				System.out.printf("*");
			}
			System.out.println();
		}
		for (int i = 0; i < 10; i+=2) {
			for (int j = 10 ; j>=i ; j--) {
				System.out.printf("*");
			}
			for (int k=0 ; k<=i ; k+=2) {
				System.out.printf(" ");
			}
			System.out.println();
		}
	}
}
